<%- include('partials/header') %>

  <!-- PAGE HERO -->
  <div class="page-hero">
    <div class="container">
      <div class="breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        <span style="color:var(--text-dark); font-weight:500;">Contact</span>
      </div>
      <h1>Let's Work Together</h1>
      <p>Ready to optimize your healthcare operations? Reach out — our team responds within 24 hours.</p>
    </div>
  </div>

  <!-- CONTACT LAYOUT -->
  <section class="contact-layout">
    <div class="container">
      <div class="contact-grid">

        <!-- Left: Info -->
        <div class="contact-info slide-in-left">
          <span class="section-tag">Get In Touch</span>
          <h2>Contact <span>D Cyber Office</span></h2>
          <p>Whether you have a question about our services, pricing, or HIPAA compliance, our team is ready to help you find the right solution for your practice.</p>

          <div class="contact-cards">
            <div class="contact-card fade-up fade-up-delay-1">
              <div class="contact-card-icon"><i class="bx bx-phone"></i></div>
              <div class="contact-card-text">
                <strong>Phone</strong>
                <span>+1 (800) 000-0000</span>
              </div>
            </div>
            <div class="contact-card fade-up fade-up-delay-2">
              <div class="contact-card-icon"><i class="bx bx-envelope"></i></div>
              <div class="contact-card-text">
                <strong>Email</strong>
                <span>info@dcyberoffice.com</span>
              </div>
            </div>
            <div class="contact-card fade-up fade-up-delay-3">
              <div class="contact-card-icon"><i class="bx bx-map"></i></div>
              <div class="contact-card-text">
                <strong>Address</strong>
                <span>Virtual Office — Serving USA Nationwide</span>
              </div>
            </div>
          </div>

          <div class="business-hours fade-up fade-up-delay-4">
            <h4><i class="bx bx-time" style="color:var(--primary);margin-right:6px"></i> Business Hours</h4>
            <div class="hours-row"><span>Monday – Friday</span><span>9:00 AM – 6:00 PM EST</span></div>
            <div class="hours-row"><span>Saturday</span><span>10:00 AM – 2:00 PM EST</span></div>
            <div class="hours-row"><span>Sunday</span><span>Emergency Support Only</span></div>
            <div class="hours-row"><span>24/7 Support Line</span><span>Always Available</span></div>
          </div>
        </div>

        <!-- Right: Form -->
        <div class="contact-form-wrap slide-in-right">
          <h3>Submit an Inquiry</h3>
          <p>Fill out the form and we'll get back to you within 24 hours.</p>

          <form id="contactForm" novalidate>
            <div class="form-grid">
              <div class="form-group">
                <label for="fullName">Full Name *</label>
                <input type="text" id="fullName" name="fullName" placeholder="Dr. John Smith" required />
              </div>
              <div class="form-group">
                <label for="company">Practice / Company *</label>
                <input type="text" id="company" name="company" placeholder="Smith Family Practice" required />
              </div>
              <div class="form-group">
                <label for="email">Email Address *</label>
                <input type="email" id="email" name="email" placeholder="john@practice.com" required />
              </div>
              <div class="form-group">
                <label for="phone">Phone Number</label>
                <input type="tel" id="phone" name="phone" placeholder="+1 (555) 000-0000" />
              </div>
              <div class="form-group full">
                <label for="service">Service Interested In</label>
                <select id="service" name="service">
                  <option value="">Select a service...</option>
                  <% services.forEach(service => { %>
                    <option value="<%= service.slug %>"><%= service.name %></option>
                  <% }) %>
                  <option value="multiple">Multiple Services</option>
                  <option value="other">Other / Custom Solution</option>
                </select>
              </div>
              <div class="form-group full">
                <label for="message">Message *</label>
                <textarea id="message" name="message" placeholder="Tell us about your practice and what challenges you're facing..." required></textarea>
              </div>
            </div>
            <div class="form-submit">
              <button type="submit" class="btn btn-primary">
                <i class="bx bx-send"></i> Submit Inquiry
              </button>
            </div>
          </form>
        </div>

      </div>
    </div>
  </section>

  <!-- MAP PLACEHOLDER -->
  <section class="map-section">
    <div class="container">
      <div class="map-wrap">
        <div class="map-placeholder">
          <div class="map-icon"><i class="bx bx-map-pin"></i></div>
          <h3>D Cyber Office</h3>
          <p>Serving Healthcare Providers Across the United States<br>Virtual — Remote — Secure — HIPAA Compliant</p>
          <a href="tel:+18000000000" class="btn btn-primary btn-sm"><i class="bx bx-phone"></i> Call Us Now</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section">
    <div class="container">
      <h2>Ready to Transform Your Practice?</h2>
      <p>Join hundreds of healthcare providers who trust D Cyber Office for their medical billing and coding needs.</p>
      <div class="cta-btns">
        <a href="/services" class="btn btn-secondary btn-lg"><i class="bx bx-grid-alt"></i> Explore Services</a>
        <a href="tel:+18000000000" class="btn btn-outline-white btn-lg"><i class="bx bx-phone"></i> Call Us Now</a>
      </div>
    </div>
  </section>

<%- include('partials/footer') %>
